<action>
    <name>Copy files</name>
    <description>copy test</description>
    <type>COPY_FILES</type>
    <attributes/>
    <copy_empty_folders>N</copy_empty_folders>
    <arg_from_previous>Y</arg_from_previous>
    <overwrite_files>Y</overwrite_files>
    <include_subfolders>Y</include_subfolders>
    <remove_source_files>Y</remove_source_files>
    <add_result_filesname>Y</add_result_filesname>
    <destination_is_a_file>Y</destination_is_a_file>
    <create_destination_folder>Y</create_destination_folder>
    <fields>
        <field>
            <source_filefolder>${SOURCE_DIR}/file1.txt</source_filefolder>
            <destination_filefolder>${DEST_DIR}/out1.txt</destination_filefolder>
            <wildcard>^file1\.txt$</wildcard>
        </field>
        <field>
            <source_filefolder>/data/in</source_filefolder>
            <destination_filefolder>/data/out</destination_filefolder>
            <wildcard/>
        </field>
    </fields>
    <parallel>N</parallel>
    <xloc>192</xloc>
    <yloc>96</yloc>
    <attributes_hac/>
</action>
