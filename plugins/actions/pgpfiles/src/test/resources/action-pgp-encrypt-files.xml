<action>
    <gpglocation>pgp-location</gpglocation>
    <arg_from_previous>Y</arg_from_previous>
    <include_subfolders>Y</include_subfolders>
    <add_result_filesname>Y</add_result_filesname>
    <destination_is_a_file>Y</destination_is_a_file>
    <create_destination_folder>Y</create_destination_folder>
    <add_date>Y</add_date>
    <add_time>Y</add_time>
    <SpecifyFormat>Y</SpecifyFormat>
    <date_time_format>date-time-format</date_time_format>
    <nr_errors_less_than>10</nr_errors_less_than>
    <success_condition>success_when_at_least</success_condition>
    <AddDateBeforeExtension>Y</AddDateBeforeExtension>
    <DoNotKeepFolderStructure>Y</DoNotKeepFolderStructure>
    <iffileexists>move_file</iffileexists>
    <destinationFolder>dest-folder</destinationFolder>
    <ifmovedfileexists>overwrite_file</ifmovedfileexists>
    <moved_date_time_format>date-time-format</moved_date_time_format>
    <create_move_to_folder>Y</create_move_to_folder>
    <add_moved_date>Y</add_moved_date>
    <add_moved_time>Y</add_moved_time>
    <SpecifyMoveFormat>Y</SpecifyMoveFormat>
    <AddMovedDateBeforeExtension>Y</AddMovedDateBeforeExtension>
    <asciiMode>Y</asciiMode>
    <fields>
        <field>
            <action_type>encrypt</action_type>
            <source_filefolder>folder1</source_filefolder>
            <userid>user1</userid>
            <destination_filefolder>target1</destination_filefolder>
            <wildcard>wildcard1</wildcard>
        </field>
        <field>
            <action_type>sign</action_type>
            <source_filefolder>folder2</source_filefolder>
            <userid>user2</userid>
            <destination_filefolder>target2</destination_filefolder>
            <wildcard>wildcard2</wildcard>
        </field>
        <field>
            <action_type>signandencrypt</action_type>
            <source_filefolder>folder3</source_filefolder>
            <userid>user3</userid>
            <destination_filefolder>target3</destination_filefolder>
            <wildcard>wildcard3</wildcard>
        </field>
    </fields>
</action>

