<transform>
    <operation_type>outputvalue</operation_type>
    <vcard_version>3.0</vcard_version>
    <output_field>vcard_text</output_field>
    <pass_input_fields>N</pass_input_fields>
    <add_prodid>N</add_prodid>
    <add_revision>N</add_revision>
    <file_name_in_field>N</file_name_in_field>
    <file_name_field>vcard_filename</file_name_field>
    <encoding>UTF-8</encoding>
    <file>
        <name>${java.io.tmpdir}/vcard-output</name>
        <extension>vcf</extension>
        <create_parent_folder>Y</create_parent_folder>
        <append>N</append>
        <add_date>N</add_date>
        <add_time>N</add_time>
        <doNotOpenNewFileInit>Y</doNotOpenNewFileInit>
    </file>
    <field>
        <hop_field>fn</hop_field>
        <property>fn</property>
        <parameter_types/>
    </field>
    <field>
        <hop_field>uid</hop_field>
        <property>uid</property>
        <parameter_types/>
    </field>
    <field>
        <hop_field>email</hop_field>
        <property>email</property>
        <parameter_types>INTERNET,WORK</parameter_types>
    </field>
    <field>
        <hop_field>email_type</hop_field>
        <property>email_type</property>
        <parameter_types>INTERNET,WORK</parameter_types>
    </field>
    <add_to_result_filenames>Y</add_to_result_filenames>
</transform>
