<pipeline>
  <info>
    <name>rest-client-slack-conversations-loop</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description/>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <pipeline_status>0</pipeline_status>
    <parameters>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2026/06/06 14:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2026/06/06 14:00:00.000</modified_date>
  </info>
  <notepads>
    <notepad>
      <backgroundcolorblue>251</backgroundcolorblue>
      <backgroundcolorgreen>232</backgroundcolorgreen>
      <backgroundcolorred>201</backgroundcolorred>
      <bordercolorblue>90</bordercolorblue>
      <bordercolorgreen>58</bordercolorgreen>
      <bordercolorred>14</bordercolorred>
      <fontbold>N</fontbold>
      <fontcolorblue>90</fontcolorblue>
      <fontcolorgreen>58</fontcolorgreen>
      <fontcolorred>14</fontcolorred>
      <fontitalic>N</fontitalic>
      <fontname>SansSerif</fontname>
      <fontsize>10</fontsize>
      <height>200</height>
      <width>720</width>
      <xloc>64</xloc>
      <yloc>32</yloc>
      <note>Lists Slack workspace channels via REST connection &quot;slack-conversations&quot; (metadata/restconnection/slack-conversations.json): BODY_CURSOR pagination on POST form body, limit=5 per page.

Slack is a public API but requires a bot token. Set the SLACK_BOT_TOKEN environment/project variable (xoxb-...) with scopes channels:read or conversations:read. The static body field supplies token and types; Hop merges limit and cursor on each page.

Split path $.channels[*] emits one row per channel. maxPagesLoops=10 is a safeguard.
</note>
    </notepad>
  </notepads>
  <transform>
    <name>generate 1 row</name>
    <type>RowGenerator</type>
    <description/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
    </fields>
    <interval_in_ms>5000</interval_in_ms>
    <last_time_field>FiveSecondsAgo</last_time_field>
    <limit>1</limit>
    <never_ending>N</never_ending>
    <row_time_field>now</row_time_field>
    <GUI>
      <xloc>128</xloc>
      <yloc>240</yloc>
    </GUI>
    <attributes/>
  </transform>
  <transform>
    <name>Slack POST body</name>
    <type>Constant</type>
    <description/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
      <field>
        <nullif>token=${SLACK_BOT_TOKEN}&amp;types=public_channel</nullif>
        <name>request_body</name>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <set_empty_string>N</set_empty_string>
      </field>
    </fields>
    <GUI>
      <xloc>320</xloc>
      <yloc>240</yloc>
    </GUI>
    <attributes/>
  </transform>
  <transform>
    <name>fetch Slack channels</name>
    <type>Rest</type>
    <description/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <applicationType>FORM URLENCODED</applicationType>
    <bodyField>request_body</bodyField>
    <connectionTimeout>60000</connectionTimeout>
    <readTimeout>60000</readTimeout>
    <connection_name>slack-conversations</connection_name>
    <url>/api/conversations.list</url>
    <urlInField>N</urlInField>
    <httpPassword>Encrypted </httpPassword>
    <preemptive>N</preemptive>
    <method>POST</method>
    <dynamicMethod>N</dynamicMethod>
    <trustStorePassword>Encrypted </trustStorePassword>
    <ignoreSsl>N</ignoreSsl>
    <paginationEnabled>Y</paginationEnabled>
    <maxPagesLoops>10</maxPagesLoops>
    <resultSplitPath>$.channels[*]</resultSplitPath>
    <headers/>
    <parameters/>
    <matrixParameters/>
    <result>
      <name>channel_json</name>
    </result>
    <retryTimes>0</retryTimes>
    <retryDelayMs>200</retryDelayMs>
    <retryStatusCodes/>
    <retryMethods/>
    <GUI>
      <xloc>528</xloc>
      <yloc>240</yloc>
    </GUI>
    <attributes/>
  </transform>
  <transform>
    <name>parse channel JSON</name>
    <type>JsonInput</type>
    <description/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <include>N</include>
    <include_field/>
    <rownum>N</rownum>
    <rownum_field/>
    <limit>0</limit>
    <valueField>channel_json</valueField>
    <IsInFields>Y</IsInFields>
    <IsAFile>N</IsAFile>
    <addresultfile>N</addresultfile>
    <IsIgnoreEmptyFile>Y</IsIgnoreEmptyFile>
    <doNotFailIfNoFile>N</doNotFailIfNoFile>
    <ignoreMissingPath>Y</ignoreMissingPath>
    <readurl>N</readurl>
    <removeSourceField>Y</removeSourceField>
    <defaultPathLeafToNull>Y</defaultPathLeafToNull>
    <files>
      <file>
        <name/>
        <filemask/>
        <exclude_filemask/>
        <file_required>N</file_required>
        <include_subfolders>N</include_subfolders>
      </file>
    </files>
    <fields>
      <field>
        <name>channel_id</name>
        <path>$.id</path>
        <type>String</type>
        <format/>
        <trim_type>none</trim_type>
        <precision>-1</precision>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <repeat>N</repeat>
      </field>
      <field>
        <name>channel_name</name>
        <path>$.name</path>
        <type>String</type>
        <format/>
        <trim_type>none</trim_type>
        <precision>-1</precision>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <repeat>N</repeat>
      </field>
      <field>
        <name>is_archived</name>
        <path>$.is_archived</path>
        <type>Boolean</type>
        <format/>
        <trim_type>none</trim_type>
        <precision>-1</precision>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <repeat>N</repeat>
      </field>
    </fields>
    <GUI>
      <xloc>736</xloc>
      <yloc>240</yloc>
    </GUI>
    <attributes/>
  </transform>
  <transform>
    <name>log channels</name>
    <type>WriteToLog</type>
    <description/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <displayHeader>Y</displayHeader>
    <limitRows>N</limitRows>
    <limitRowsNumber>0</limitRowsNumber>
    <logmessage>Slack channel row</logmessage>
    <loglevel>Basic</loglevel>
    <fields>
      <field>
        <name>channel_id</name>
      </field>
      <field>
        <name>channel_name</name>
      </field>
      <field>
        <name>is_archived</name>
      </field>
    </fields>
    <GUI>
      <xloc>944</xloc>
      <yloc>240</yloc>
    </GUI>
    <attributes/>
  </transform>
  <order>
    <hop>
      <from>generate 1 row</from>
      <to>Slack POST body</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Slack POST body</from>
      <to>fetch Slack channels</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>fetch Slack channels</from>
      <to>parse channel JSON</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>parse channel JSON</from>
      <to>log channels</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <attributes/>
</pipeline>
