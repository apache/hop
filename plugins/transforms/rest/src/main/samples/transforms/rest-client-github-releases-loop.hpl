<pipeline>
  <info>
    <name>rest-client-github-releases-loop</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description/>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <pipeline_status>0</pipeline_status>
    <parameters>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2026/05/16 12:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2026/05/16 12:00:00.000</modified_date>
  </info>
  <notepads>
    <notepad>
      <backgroundcolorblue>251</backgroundcolorblue>
      <backgroundcolorgreen>232</backgroundcolorgreen>
      <backgroundcolorred>201</backgroundcolorred>
      <bordercolorblue>90</bordercolorblue>
      <bordercolorgreen>58</bordercolorgreen>
      <bordercolorred>14</bordercolorred>
      <fontbold>N</fontbold>
      <fontcolorblue>90</fontcolorblue>
      <fontcolorgreen>58</fontcolorgreen>
      <fontcolorred>14</fontcolorred>
      <fontitalic>N</fontitalic>
      <fontname>SansSerif</fontname>
      <fontsize>10</fontsize>
      <height>168</height>
      <width>640</width>
      <xloc>64</xloc>
      <yloc>32</yloc>
      <note>Lists apache/hop GitHub releases via REST connection &quot;github-releases&quot; (metadata/restconnection/github-releases.json): No Auth (public API), LINK_HEADER pagination, per_page=5.

About 20 releases total → ~4 HTTP pages. maxPagesLoops=8 is a safe upper bound. Requires User-Agent. Authentication is optional; a 401 usually means an invalid Bearer token was sent (e.g. unset GH_TOKEN left as ${GH_TOKEN}). For higher rate limits, edit the connection to Bearer and set a valid GitHub PAT in GH_TOKEN.

Split path $[*] on the top-level JSON array returned by GET /repos/apache/hop/releases.
</note>
    </notepad>
  </notepads>
  <transform>
    <name>generate 1 row</name>
    <type>RowGenerator</type>
    <description/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
    </fields>
    <interval_in_ms>5000</interval_in_ms>
    <last_time_field>FiveSecondsAgo</last_time_field>
    <limit>1</limit>
    <never_ending>N</never_ending>
    <row_time_field>now</row_time_field>
    <GUI>
      <xloc>128</xloc>
      <yloc>240</yloc>
    </GUI>
    <attributes/>
  </transform>
  <transform>
    <name>GitHub request headers</name>
    <type>Constant</type>
    <description/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
      <field>
        <nullif>Hop-rest-client-github-releases-loop (https://github.com/apache/hop/releases)</nullif>
        <name>user_agent</name>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <set_empty_string>N</set_empty_string>
      </field>
      <field>
        <nullif>application/vnd.github+json</nullif>
        <name>accept_media</name>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <set_empty_string>N</set_empty_string>
      </field>
    </fields>
    <GUI>
      <xloc>320</xloc>
      <yloc>240</yloc>
    </GUI>
    <attributes/>
  </transform>
  <transform>
    <name>fetch apache-hop releases</name>
    <type>Rest</type>
    <description/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <applicationType>JSON</applicationType>
    <connectionTimeout>60000</connectionTimeout>
    <readTimeout>60000</readTimeout>
    <connection_name>github-releases</connection_name>
    <url>/repos/apache/hop/releases?per_page=5</url>
    <urlInField>N</urlInField>
    <httpPassword>Encrypted </httpPassword>
    <preemptive>N</preemptive>
    <method>GET</method>
    <dynamicMethod>N</dynamicMethod>
    <trustStorePassword>Encrypted </trustStorePassword>
    <ignoreSsl>N</ignoreSsl>
    <paginationEnabled>Y</paginationEnabled>
    <maxPagesLoops>8</maxPagesLoops>
    <resultSplitPath>$[*]</resultSplitPath>
    <headers>
      <header>
        <field>user_agent</field>
        <name>User-Agent</name>
      </header>
      <header>
        <field>accept_media</field>
        <name>Accept</name>
      </header>
    </headers>
    <parameters/>
    <matrixParameters/>
    <result>
      <name>release_json</name>
    </result>
    <retryTimes>0</retryTimes>
    <retryDelayMs>200</retryDelayMs>
    <retryStatusCodes/>
    <retryMethods/>
    <GUI>
      <xloc>528</xloc>
      <yloc>240</yloc>
    </GUI>
    <attributes/>
  </transform>
  <transform>
    <name>parse release JSON</name>
    <type>JsonInput</type>
    <description/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <include>N</include>
    <include_field/>
    <rownum>N</rownum>
    <rownum_field/>
    <limit>0</limit>
    <valueField>release_json</valueField>
    <IsInFields>Y</IsInFields>
    <IsAFile>N</IsAFile>
    <addresultfile>N</addresultfile>
    <IsIgnoreEmptyFile>Y</IsIgnoreEmptyFile>
    <doNotFailIfNoFile>N</doNotFailIfNoFile>
    <ignoreMissingPath>Y</ignoreMissingPath>
    <readurl>N</readurl>
    <removeSourceField>Y</removeSourceField>
    <defaultPathLeafToNull>Y</defaultPathLeafToNull>
    <files>
      <file>
        <name/>
        <filemask/>
        <exclude_filemask/>
        <file_required>N</file_required>
        <include_subfolders>N</include_subfolders>
      </file>
    </files>
    <fields>
      <field>
        <name>tag_name</name>
        <path>$.tag_name</path>
        <type>String</type>
        <format/>
        <trim_type>none</trim_type>
        <precision>-1</precision>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <repeat>N</repeat>
      </field>
      <field>
        <name>release_name</name>
        <path>$.name</path>
        <type>String</type>
        <format/>
        <trim_type>none</trim_type>
        <precision>-1</precision>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <repeat>N</repeat>
      </field>
      <field>
        <name>published_at</name>
        <path>$.published_at</path>
        <type>String</type>
        <format/>
        <trim_type>none</trim_type>
        <precision>-1</precision>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <repeat>N</repeat>
      </field>
      <field>
        <name>draft</name>
        <path>$.draft</path>
        <type>Boolean</type>
        <format/>
        <trim_type>none</trim_type>
        <precision>-1</precision>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <repeat>N</repeat>
      </field>
      <field>
        <name>html_url</name>
        <path>$.html_url</path>
        <type>String</type>
        <format/>
        <trim_type>none</trim_type>
        <precision>-1</precision>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <repeat>N</repeat>
      </field>
    </fields>
    <GUI>
      <xloc>736</xloc>
      <yloc>240</yloc>
    </GUI>
    <attributes/>
  </transform>
  <transform>
    <name>log releases</name>
    <type>WriteToLog</type>
    <description/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <displayHeader>Y</displayHeader>
    <limitRows>N</limitRows>
    <limitRowsNumber>0</limitRowsNumber>
    <logmessage>apache/hop GitHub release row</logmessage>
    <loglevel>Basic</loglevel>
    <fields>
      <field>
        <name>tag_name</name>
      </field>
      <field>
        <name>release_name</name>
      </field>
      <field>
        <name>published_at</name>
      </field>
      <field>
        <name>draft</name>
      </field>
      <field>
        <name>html_url</name>
      </field>
    </fields>
    <GUI>
      <xloc>944</xloc>
      <yloc>240</yloc>
    </GUI>
    <attributes/>
  </transform>
  <order>
    <hop>
      <from>generate 1 row</from>
      <to>GitHub request headers</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>GitHub request headers</from>
      <to>fetch apache-hop releases</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>fetch apache-hop releases</from>
      <to>parse release JSON</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>parse release JSON</from>
      <to>log releases</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <attributes/>
</pipeline>
