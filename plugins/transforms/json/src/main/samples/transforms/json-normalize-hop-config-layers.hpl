<pipeline>
  <info>
    <name>json-normalize-hop-config-layers</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Read hop-config-shaped JSON in two layers: one wide row (arrays as JSON text), then expand variables, lifecycleEnvironments, and projectConfigurations in parallel branches.</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters/>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2026/05/09 12:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2026/05/09 12:00:00.000</modified_date>
  </info>
  <notepads>
    <notepad>
      <backgroundcolorblue>251</backgroundcolorblue>
      <backgroundcolorgreen>232</backgroundcolorgreen>
      <backgroundcolorred>201</backgroundcolorred>
      <bordercolorblue>90</bordercolorblue>
      <bordercolorgreen>58</bordercolorgreen>
      <bordercolorred>14</bordercolorred>
      <fontbold>N</fontbold>
      <fontcolorblue>90</fontcolorblue>
      <fontcolorgreen>58</fontcolorgreen>
      <fontcolorred>14</fontcolorred>
      <fontitalic>N</fontitalic>
      <fontname>Noto Sans</fontname>
      <fontsize>10</fontsize>
      <height>140</height>
      <xloc>48</xloc>
      <yloc>32</yloc>
      <note>1) Wide row: Record JsonPath $ emits one row; nested JSON arrays are stringified (hop-config variables, lifecycleEnvironments, …).&#x0a;2) Three JSON Normalize Input transforms read those strings (Source from previous transform). Record JsonPath $[*] unwraps each JSON array.&#x0a;3) The first transform uses *copy* (distribute=N) so the single wide row reaches all three branches; round-robin would leave two streams empty.&#x0a;File: ${HOP_CONFIG_FOLDER}/hop-config.json. Expect very wide output on large real configs.</note>
      <width>720</width>
    </notepad>
  </notepads>
  <order>
    <hop>
      <from>wide hop-config root</from>
      <to>variables as rows</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>wide hop-config root</from>
      <to>lifecycle environments as rows</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>wide hop-config root</from>
      <to>project configurations as rows</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>variables as rows</from>
      <to>preview variables</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>lifecycle environments as rows</from>
      <to>preview lifecycles</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>project configurations as rows</from>
      <to>preview project configs</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>wide hop-config root</name>
    <type>JsonNormalizeInput</type>
    <description/>
    <distribute>N</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <include>N</include>
    <include_field/>
    <rownum>N</rownum>
    <addresultfile>N</addresultfile>
    <readurl>N</readurl>
    <removeSourceField>N</removeSourceField>
    <IsIgnoreEmptyFile>N</IsIgnoreEmptyFile>
    <doNotFailIfNoFile>Y</doNotFailIfNoFile>
    <ignoreMissingField>Y</ignoreMissingField>
    <recordPath>$</recordPath>
    <fieldSeparator>.</fieldSeparator>
    <maxFlattenDepth>-1</maxFlattenDepth>
    <arrayHandling>STRINGIFY</arrayHandling>
    <beyondDepthBehavior>STRINGIFY</beyondDepthBehavior>
    <rownum_field/>
    <limit>0</limit>
    <valueField/>
    <IsInFields>N</IsInFields>
    <IsAFile>N</IsAFile>
    <shortFileFieldName/>
    <pathFieldName/>
    <hiddenFieldName/>
    <lastModificationTimeFieldName/>
    <uriNameFieldName/>
    <rootUriNameFieldName/>
    <extensionFieldName/>
    <sizeFieldName/>
    <file>
      <name>${HOP_CONFIG_FOLDER}/hop-config.json</name>
      <filemask/>
      <exclude_filemask/>
      <file_required>N</file_required>
      <include_subfolders>N</include_subfolders>
    </file>
    <fields>
      <field>
        <name>LocaleDefault</name>
        <path>LocaleDefault</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>variables</name>
        <path>variables</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>projectsConfig_enabled</name>
        <path>projectsConfig.enabled</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>lifecycleEnvironments</name>
        <path>projectsConfig.lifecycleEnvironments</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>projectConfigurations</name>
        <path>projectsConfig.projectConfigurations</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>128</xloc>
      <yloc>300</yloc>
    </GUI>
  </transform>
  <transform>
    <name>variables as rows</name>
    <type>JsonNormalizeInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <include>N</include>
    <include_field/>
    <rownum>N</rownum>
    <addresultfile>N</addresultfile>
    <readurl>N</readurl>
    <removeSourceField>N</removeSourceField>
    <IsIgnoreEmptyFile>N</IsIgnoreEmptyFile>
    <doNotFailIfNoFile>Y</doNotFailIfNoFile>
    <ignoreMissingField>Y</ignoreMissingField>
    <recordPath>$[*]</recordPath>
    <fieldSeparator>.</fieldSeparator>
    <maxFlattenDepth>-1</maxFlattenDepth>
    <arrayHandling>STRINGIFY</arrayHandling>
    <beyondDepthBehavior>STRINGIFY</beyondDepthBehavior>
    <rownum_field/>
    <limit>0</limit>
    <valueField>variables</valueField>
    <IsInFields>Y</IsInFields>
    <IsAFile>N</IsAFile>
    <shortFileFieldName/>
    <pathFieldName/>
    <hiddenFieldName/>
    <lastModificationTimeFieldName/>
    <uriNameFieldName/>
    <rootUriNameFieldName/>
    <extensionFieldName/>
    <sizeFieldName/>
    <files/>
    <fields>
      <field>
        <name>var_name</name>
        <path>name</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>var_value</name>
        <path>value</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>var_description</name>
        <path>description</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>448</xloc>
      <yloc>204</yloc>
    </GUI>
  </transform>
  <transform>
    <name>lifecycle environments as rows</name>
    <type>JsonNormalizeInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <include>N</include>
    <include_field/>
    <rownum>N</rownum>
    <addresultfile>N</addresultfile>
    <readurl>N</readurl>
    <removeSourceField>N</removeSourceField>
    <IsIgnoreEmptyFile>N</IsIgnoreEmptyFile>
    <doNotFailIfNoFile>Y</doNotFailIfNoFile>
    <ignoreMissingField>Y</ignoreMissingField>
    <recordPath>$[*]</recordPath>
    <fieldSeparator>.</fieldSeparator>
    <maxFlattenDepth>-1</maxFlattenDepth>
    <arrayHandling>STRINGIFY</arrayHandling>
    <beyondDepthBehavior>STRINGIFY</beyondDepthBehavior>
    <rownum_field/>
    <limit>0</limit>
    <valueField>lifecycleEnvironments</valueField>
    <IsInFields>Y</IsInFields>
    <IsAFile>N</IsAFile>
    <shortFileFieldName/>
    <pathFieldName/>
    <hiddenFieldName/>
    <lastModificationTimeFieldName/>
    <uriNameFieldName/>
    <rootUriNameFieldName/>
    <extensionFieldName/>
    <sizeFieldName/>
    <files/>
    <fields>
      <field>
        <name>lifecycle_name</name>
        <path>name</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>lifecycle_purpose</name>
        <path>purpose</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>lifecycle_projectName</name>
        <path>projectName</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>lifecycle_configurationFiles_json</name>
        <path>configurationFiles</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>448</xloc>
      <yloc>300</yloc>
    </GUI>
  </transform>
  <transform>
    <name>project configurations as rows</name>
    <type>JsonNormalizeInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <include>N</include>
    <include_field/>
    <rownum>N</rownum>
    <addresultfile>N</addresultfile>
    <readurl>N</readurl>
    <removeSourceField>N</removeSourceField>
    <IsIgnoreEmptyFile>N</IsIgnoreEmptyFile>
    <doNotFailIfNoFile>Y</doNotFailIfNoFile>
    <ignoreMissingField>Y</ignoreMissingField>
    <recordPath>$[*]</recordPath>
    <fieldSeparator>.</fieldSeparator>
    <maxFlattenDepth>-1</maxFlattenDepth>
    <arrayHandling>STRINGIFY</arrayHandling>
    <beyondDepthBehavior>STRINGIFY</beyondDepthBehavior>
    <rownum_field/>
    <limit>0</limit>
    <valueField>projectConfigurations</valueField>
    <IsInFields>Y</IsInFields>
    <IsAFile>N</IsAFile>
    <shortFileFieldName/>
    <pathFieldName/>
    <hiddenFieldName/>
    <lastModificationTimeFieldName/>
    <uriNameFieldName/>
    <rootUriNameFieldName/>
    <extensionFieldName/>
    <sizeFieldName/>
    <files/>
    <fields>
      <field>
        <name>projectName</name>
        <path>projectName</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>projectHome</name>
        <path>projectHome</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>configFilename</name>
        <path>configFilename</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>448</xloc>
      <yloc>396</yloc>
    </GUI>
  </transform>
  <transform>
    <name>preview variables</name>
    <type>Dummy</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
    <GUI>
      <xloc>768</xloc>
      <yloc>204</yloc>
    </GUI>
  </transform>
  <transform>
    <name>preview lifecycles</name>
    <type>Dummy</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
