<transform>
    <script>regular-expression</script>
    <matcher>regex-field</matcher>
    <resultfieldname>result</resultfieldname>
    <usevar>Y</usevar>
    <allowcapturegroups>Y</allowcapturegroups>
    <replacefields>Y</replacefields>
    <canoneq>Y</canoneq>
    <caseinsensitive>Y</caseinsensitive>
    <comment>Y</comment>
    <dotall>Y</dotall>
    <multiline>Y</multiline>
    <unicode>Y</unicode>
    <unix>Y</unix>
    <fields>
        <field>
            <name>field1</name>
            <type>String</type>
            <format/>
            <group/>
            <decimal/>
            <length>100</length>
            <precision>-1</precision>
            <nullif/>
            <ifnull/>
            <trimtype>left</trimtype>
            <currency/>
        </field>
        <field>
            <name>field2</name>
            <type>Integer</type>
            <format/>
            <group/>
            <decimal/>
            <length>7</length>
            <precision>0</precision>
            <nullif/>
            <ifnull/>
            <trimtype>right</trimtype>
            <currency/>
        </field>
        <field>
            <name>field3</name>
            <type>Number</type>
            <format/>
            <group/>
            <decimal/>
            <length>9</length>
            <precision>2</precision>
            <nullif/>
            <ifnull/>
            <trimtype>both</trimtype>
            <currency/>
        </field>
    </fields>
</transform>

