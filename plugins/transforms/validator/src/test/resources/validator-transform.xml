<transform>
  <name>Data validator</name>
  <type>Validator</type>
  <description/>
  <distribute>Y</distribute>
  <custom_distribution/>
  <copies>1</copies>
  <partitioning>
    <method>none</method>
    <schema_name/>
  </partitioning>
  <concat_errors>Y</concat_errors>
  <concat_separator>;</concat_separator>
  <validate_all>Y</validate_all>
  <suppress_log_failed_data>Y</suppress_log_failed_data>
  <validator_field>
    <allowed_value>
      <value>A</value>
      <value>B</value>
    </allowed_value>
    <conversion_mask/>
    <data_type>String</data_type>
    <data_type_verified>N</data_type_verified>
    <decimal_symbol/>
    <error_code>CODE_NULL</error_code>
    <error_description>Field value cannot be null</error_description>
    <grouping_symbol/>
    <is_sourcing_values>N</is_sourcing_values>
    <max_length>10</max_length>
    <min_length>1</min_length>
    <name>value</name>
    <null_allowed>N</null_allowed>
    <only_null_allowed>N</only_null_allowed>
    <only_numeric_allowed>N</only_numeric_allowed>
    <validation_name>value rules</validation_name>
  </validator_field>
  <attributes/>
  <GUI>
    <xloc>100</xloc>
    <yloc>100</yloc>
  </GUI>
</transform>
