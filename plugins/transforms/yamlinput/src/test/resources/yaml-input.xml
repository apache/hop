    <doNotFailIfNoFile>Y</doNotFailIfNoFile>
    <rownum_field>rowNumField</rownum_field>
    <encoding>UTF-8</encoding>
    <file>
        <name>folder1/</name>
        <filemask>.*\.yaml</filemask>
        <file_required>Y</file_required>
        <include_subfolders>Y</include_subfolders>
        <name>folder1/</name>
        <filemask>.*\.yml</filemask>
        <file_required>Y</file_required>
        <include_subfolders>Y</include_subfolders>
    </file>
    <fields>
        <field>
            <name>field1</name>
            <path>key1</path>
            <type>String</type>
            <format/>
