        <artifactId>hop-plugins-tech</artifactId>
        <version>2.18.1</version>
    </parent>

    <artifactId>hop-tech-arrow</artifactId>
    <packaging>jar</packaging>
    <name>Hop Plugins Technology Apache Arrow</name>

    <properties>
        <apache.arrow.version>19.0.0</apache.arrow.version>
