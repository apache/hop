<pipeline>
  <info>
    <name>enrich-by-country</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Nested Native Spark child: full Dataset job parameterized by COUNTRY_NAME. Reads shared customers sample and writes under HOP_DATA/out/by-country/${COUNTRY_NAME}/ (proves nested SparkPipelineEngine reuses parent session).</description>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
      <parameter>
        <name>COUNTRY_NAME</name>
        <default_value>Unknown</default_value>
        <description>Country key from the parent Pipeline Executor</description>
      </parameter>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <created_user>-</created_user>
    <created_date>2026/07/17 00:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2026/07/17 00:00:00.000</modified_date>
  </info>
  <notepads/>
  <order>
    <hop>
      <from>Spark File Input</from>
      <to>Spark File Output</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <type>SparkFileInput</type>
    <name>Spark File Input</name>
    <description>Shared fact sample — path uses HOP_DATA, not package PROJECT_HOME</description>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <file_path>${HOP_DATA}/customers-sample.csv</file_path>
    <file_format>csv</file_format>
    <header>Y</header>
    <separator>,</separator>
    <quote>"</quote>
    <infer_schema>N</infer_schema>
    <multi_line>N</multi_line>
    <extra_options/>
    <fields>
      <field>
        <name>id</name>
        <type>Integer</type>
        <length>9</length>
        <precision>-1</precision>
      </field>
      <field>
        <name>firstname</name>
        <type>String</type>
        <length>50</length>
        <precision>-1</precision>
      </field>
      <field>
        <name>lastname</name>
        <type>String</type>
        <length>50</length>
        <precision>-1</precision>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>128</xloc>
      <yloc>128</yloc>
    </GUI>
  </transform>
  <transform>
    <type>SparkFileOutput</type>
    <name>Spark File Output</name>
    <description>Per-country sink — parameter COUNTRY_NAME from parent orchestrator</description>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <file_path>${HOP_DATA}/out/by-country/${COUNTRY_NAME}</file_path>
    <file_format>csv</file_format>
    <save_mode>Overwrite</save_mode>
    <header>Y</header>
    <separator>,</separator>
    <quote>"</quote>
    <partition_by/>
    <coalesce>1</coalesce>
    <extra_options/>
    <attributes/>
    <GUI>
      <xloc>384</xloc>
      <yloc>128</yloc>
    </GUI>
  </transform>
  <transform_error_handling/>
  <attributes/>
</pipeline>
