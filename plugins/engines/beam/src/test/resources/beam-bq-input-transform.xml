<transform>
  <name>BigQuery Input</name>
  <type>BeamBQInput</type>
  <description/>
  <distribute>Y</distribute>
  <custom_distribution/>
  <copies>1</copies>
  <partitioning>
    <method>none</method>
    <schema_name/>
  </partitioning>
  <project_id>test-project</project_id>
  <dataset_id>test_dataset</dataset_id>
  <table_id>test_table</table_id>
  <query>SELECT id, name FROM `test-project.test_dataset.test_table`</query>
  <fields>
    <field>
      <name>id</name>
      <type>Integer</type>
    </field>
    <field>
      <name>name</name>
      <type>String</type>
      <new_name>renamed_name</new_name>
    </field>
  </fields>
  <attributes/>
</transform>
