<transform>
    <name>Mail input</name>
    <type>MailInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
        <method>none</method>
        <schema_name/>
    </partitioning>
    <servername>imap.example.com</servername>
    <username>alice</username>
    <password>secret</password>
    <usessl>Y</usessl>
    <sslport>993</sslport>
    <usexoauth2>N</usexoauth2>
    <protocol>IMAP</protocol>
    <imapfolder>INBOX</imapfolder>
    <firstmails>0</firstmails>
    <imapfirstmails>10</imapfirstmails>
    <delete>N</delete>
    <senderSearch>boss@example.com</senderSearch>
    <notTermSenderSearch>N</notTermSenderSearch>
    <recipientSearch>me@example.com</recipientSearch>
    <subjectSearch>invoice</subjectSearch>
    <notTermSubjectSearch>N</notTermSubjectSearch>
    <notTermRecipientSearch>N</notTermRecipientSearch>
    <receivedDate1>2025/01/01 00:00:00</receivedDate1>
    <receivedDate2>2025/12/31 23:59:59</receivedDate2>
    <notTermReceivedDateSearch>N</notTermReceivedDateSearch>
    <includesubfolders>N</includesubfolders>
    <useproxy>N</useproxy>
    <usedynamicfolder>N</usedynamicfolder>
    <rowlimit>0</rowlimit>
    <fields>
        <field>
            <name>messageNumber</name>
            <column>Message: Number</column>
        </field>
        <field>
            <name>subject</name>
            <column>Message: Subject</column>
        </field>
    </fields>
    <attributes></attributes>
    <GUI>
        <xloc>304</xloc>
        <yloc>64</yloc>
    </GUI>
</transform>
