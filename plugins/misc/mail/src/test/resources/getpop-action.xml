<action>
    <name>Get mails (POP3/IMAP)</name>
    <description/>
    <type>GET_POP</type>
    <servername>imap.example.com</servername>
    <username>alice</username>
    <password>secret</password>
    <usessl>Y</usessl>
    <sslport>993</sslport>
    <usexoauth2>N</usexoauth2>
    <useproxy>N</useproxy>
    <outputdirectory>/tmp/mail</outputdirectory>
    <filenamepattern>mail_%date</filenamepattern>
    <firstmails>5</firstmails>
    <delete>N</delete>
    <protocol>IMAP</protocol>
    <saveattachment>Y</saveattachment>
    <savemessage>Y</savemessage>
    <usedifferentfolderforattachment>N</usedifferentfolderforattachment>
    <imapfirstmails>10</imapfirstmails>
    <imapfolder>INBOX</imapfolder>
    <sendersearch>boss@example.com</sendersearch>
    <nottermsendersearch>N</nottermsendersearch>
    <recipientsearch>me@example.com</recipientsearch>
    <subjectsearch>invoice</subjectsearch>
    <bodysearch>urgent</bodysearch>
    <includesubfolders>N</includesubfolders>
    <attributes/>
    <parallel>N</parallel>
    <xloc>240</xloc>
    <yloc>128</yloc>
    <attributes_hac/>
</action>
