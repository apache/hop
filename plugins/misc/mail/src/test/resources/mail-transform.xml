<transform>
    <name>Send mail</name>
    <type>Mail</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
        <method>none</method>
        <schema_name/>
    </partitioning>
    <server>smtp.example.com</server>
    <port>587</port>
    <destination>to@example.com</destination>
    <destinationCc>cc@example.com</destinationCc>
    <destinationBCc>bcc@example.com</destinationBCc>
    <replyto>bot@example.com</replyto>
    <replytoname>Bot</replytoname>
    <subject>Test subject</subject>
    <include_date>Y</include_date>
    <contact_person>Alice</contact_person>
    <contact_phone>+1</contact_phone>
    <comment>hello world</comment>
    <include_files>N</include_files>
    <zip_files>N</zip_files>
    <use_auth>Y</use_auth>
    <auth_user>alice</auth_user>
    <auth_password>secret</auth_password>
    <usexoauth2>N</usexoauth2>
    <only_comment>N</only_comment>
    <use_HTML>Y</use_HTML>
    <use_secure_auth>Y</use_secure_auth>
    <use_Priority>Y</use_Priority>
    <priority>high</priority>
    <importance>high</importance>
    <sensitivity>normal</sensitivity>
    <secureconnectiontype>TLS</secureconnectiontype>
    <encoding>UTF-8</encoding>
    <check_server_identity>Y</check_server_identity>
    <trusted_hosts>smtp.example.com</trusted_hosts>
    <attributes></attributes>
    <GUI>
        <xloc>304</xloc>
        <yloc>64</yloc>
    </GUI>
</transform>
