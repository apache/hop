<workflow>
  <name>main-0013-mongodbql-succes</name>
  <name_sync_with_filename>Y</name_sync_with_filename>
  <description/>
  <extended_description/>
  <created_user>-</created_user>
  <modified_user>-</modified_user>
  <created_date>2026/03/19 09:47:37.852</created_date>
  <modified_date>2026/03/19 09:47:37.852</modified_date>
  <workflow_version/>
  <parameters>
    <parameter>
      <name>MONGO_CONNECTION</name>
      <description/>
      <default_value>mongo</default_value>
    </parameter>
  </parameters>
  <actions>
    <action>
      <repeat>N</repeat>
      <schedulerType>0</schedulerType>
      <intervalSeconds>0</intervalSeconds>
      <intervalMinutes>60</intervalMinutes>
      <DayOfMonth>1</DayOfMonth>
      <weekDay>1</weekDay>
      <minutes>0</minutes>
      <hour>12</hour>
      <doNotWaitOnFirstExecution>N</doNotWaitOnFirstExecution>
      <name>Start</name>
      <description/>
      <type>SPECIAL</type>
      <attributes/>
      <xloc>48</xloc>
      <yloc>48</yloc>
      <parallel>N</parallel>
      <attributes_hac/>
    </action>
    <action>
      <mql>[
  {"create": "test_collection"},
  {"listCollections": 1},
  {
    "insert": "test_collection",
    "documents": [
      {
        "name": "Dark Magician",
        "type": "Monster",
        "attribute": "DARK",
        "level": 7,
        "atk": 2500,
        "def": 2100,
        "description": "The ultimate wizard in terms of attack and defense.",
        "archetype": "Dark Magician"
      },
      {
        "name": "Blue-Eyes White Dragon",
        "type": "Monster",
        "attribute": "LIGHT",
        "level": 8,
        "atk": 3000,
        "def": 2500,
        "description": "This legendary dragon is a powerful engine of destruction.",
        "archetype": "Blue-Eyes"
      },
      {
        "name": "Exodia the Forbidden One",
        "type": "Monster",
        "attribute": "DARK",
        "level": 3,
        "atk": 1000,
        "def": 1000,
        "description": "If you have all 5 Exodia pieces in your hand, you win instantly.",
        "archetype": "Exodia"
      },
      {
        "name": "Mirror Force",
        "type": "Trap",
        "trap_type": "Normal",
        "description": "Destroy all attack position monsters your opponent controls."
      },
      {
        "name": "Monster Reborn",
        "type": "Spell",
        "spell_type": "Normal",
        "description": "Target 1 monster in either player's GY; Special Summon it."
      },
      {
        "name": "Pot of Greed",
        "type": "Spell",
        "spell_type": "Normal",
        "description": "Draw 2 cards."
      },
      {
        "name": "Red-Eyes Black Dragon",
        "type": "Monster",
        "attribute": "DARK",
        "level": 7,
        "atk": 2400,
        "def": 2000,
        "description": "A ferocious dragon with a deadly attack.",
        "archetype": "Red-Eyes"
      },
      {
        "name": "Summoned Skull",
        "type": "Monster",
        "attribute": "DARK",
        "level": 6,
        "atk": 2500,
        "def": 1200,
        "description": "A fiend with dark powers for attacking enemy monsters.",
        "archetype": "Archfiend"
      }
    ]
  }
]</mql>
      <connection>${MONGO_CONNECTION}</connection>
      <useExternalFile>N</useExternalFile>
      <commandFile/>
      <useVariableSubstitution>Y</useVariableSubstitution>
      <name>MongoDB QL</name>
      <description/>
      <type>MQL</type>
      <attributes/>
      <xloc>176</xloc>
      <yloc>48</yloc>
      <parallel>N</parallel>
      <attributes_hac/>
    </action>
    <action>
      <name>Success</name>
      <description/>
      <type>SUCCESS</type>
      <attributes/>
      <xloc>864</xloc>
      <yloc>48</yloc>
      <parallel>N</parallel>
      <attributes_hac/>
    </action>
    <action>
      <filename>${PROJECT_HOME}/tests/mongo-execMql/verify-inserted-documents.hpl</filename>
      <params_from_previous>N</params_from_previous>
      <exec_per_row>N</exec_per_row>
      <clear_rows>N</clear_rows>
      <clear_files>N</clear_files>
      <create_parent_folder>N</create_parent_folder>
      <set_logfile>N</set_logfile>
      <set_append_logfile>N</set_append_logfile>
      <logfile/>
      <logext/>
      <add_date>N</add_date>
      <add_time>N</add_time>
      <loglevel>Basic</loglevel>
      <wait_until_finished>Y</wait_until_finished>
      <parameters>
        <pass_all_parameters>Y</pass_all_parameters>
      </parameters>
      <run_configuration>local</run_configuration>
      <name>verify-inserted-documents.hpl</name>
      <description/>
      <type>PIPELINE</type>
      <attributes/>
      <xloc>384</xloc>
      <yloc>48</yloc>
      <parallel>N</parallel>
      <attributes_hac/>
    </action>
    <action>
      <always_log_rows>N</always_log_rows>
      <name>Abort workflow</name>
      <description/>
      <type>ABORT</type>
      <attributes/>
      <xloc>384</xloc>
      <yloc>176</yloc>
      <parallel>N</parallel>
      <attributes_hac/>
    </action>
    <action>
      <mql>{"drop":"test_collection"}</mql>
      <connection>${MONGO_CONNECTION}</connection>
      <useExternalFile>N</useExternalFile>
      <commandFile/>
      <useVariableSubstitution>Y</useVariableSubstitution>
      <name>delete collection</name>
      <description/>
      <type>MQL</type>
      <attributes/>
      <xloc>624</xloc>
      <yloc>48</yloc>
      <parallel>N</parallel>
      <attributes_hac/>
    </action>
  </actions>
  <hops>
    <hop>
      <from>Start</from>
      <to>MongoDB QL</to>
      <evaluation>Y</evaluation>
      <unconditional>Y</unconditional>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>MongoDB QL</from>
      <to>verify-inserted-documents.hpl</to>
      <evaluation>Y</evaluation>
      <unconditional>N</unconditional>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>verify-inserted-documents.hpl</from>
      <to>Abort workflow</to>
      <evaluation>N</evaluation>
      <unconditional>N</unconditional>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>verify-inserted-documents.hpl</from>
      <to>delete collection</to>
      <evaluation>Y</evaluation>
      <unconditional>N</unconditional>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>delete collection</from>
      <to>Success</to>
      <evaluation>Y</evaluation>
      <unconditional>N</unconditional>
      <enabled>Y</enabled>
    </hop>
  </hops>
  <notepads/>
  <attributes/>
</workflow>
