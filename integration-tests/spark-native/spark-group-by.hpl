<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <pipeline_type>Normal</pipeline_type>
    <pipeline_status>-1</pipeline_status>
    <parameters/>
    <name>New pipeline</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <created_user>-</created_user>
    <modified_user>-</modified_user>
    <created_date>2026/07/15 16:26:00.453</created_date>
    <modified_date>2026/07/15 16:26:00.453</modified_date>
  </info>
  <transform>
    <type>SparkFileInput</type>
    <name>files/customers-1k.txt</name>
    <file_path>${PROJECT_HOME}/files/customers-1k.txt</file_path>
    <file_format>csv</file_format>
    <header>Y</header>
    <separator>;</separator>
    <quote>"</quote>
    <infer_schema>N</infer_schema>
    <multi_line>N</multi_line>
    <extra_options/>
    <fields>
      <field>
        <name>id</name>
        <type>Integer</type>
        <length>7</length>
        <precision>-1</precision>
      </field>
      <field>
        <name>name</name>
        <type>String</type>
        <length>50</length>
        <precision>-1</precision>
      </field>
      <field>
        <name>firstname</name>
        <type>String</type>
        <length>50</length>
        <precision>-1</precision>
      </field>
      <field>
        <name>zip</name>
        <type>String</type>
        <length>50</length>
        <precision>-1</precision>
      </field>
      <field>
        <name>city</name>
        <type>String</type>
        <length>50</length>
        <precision>-1</precision>
      </field>
      <field>
        <name>birthdate</name>
        <type>Date</type>
        <length>-1</length>
        <precision>-1</precision>
      </field>
      <field>
        <name>street</name>
        <type>String</type>
        <length>50</length>
        <precision>-1</precision>
      </field>
      <field>
        <name>housenr</name>
        <type>String</type>
        <length>50</length>
        <precision>-1</precision>
      </field>
      <field>
        <name>stateCode</name>
        <type>String</type>
        <length>2</length>
        <precision>-1</precision>
      </field>
      <field>
        <name>state</name>
        <type>String</type>
        <length>50</length>
        <precision>-1</precision>
      </field>
    </fields>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>176</xloc>
      <yloc>96</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>MemoryGroupBy</type>
    <name>count by state</name>
    <group>
      <field>
        <name>state</name>
      </field>
    </group>
    <fields>
      <field>
        <aggregate>count</aggregate>
        <subject/>
        <type>COUNT_ANY</type>
        <valuefield/>
      </field>
    </fields>
    <give_back_row>N</give_back_row>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>352</xloc>
      <yloc>96</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>SparkFileOutput</type>
    <name>output/group-by.csv</name>
    <file_path>${PROJECT_HOME}/output/group-by</file_path>
    <file_format>csv</file_format>
    <save_mode>Overwrite</save_mode>
    <header>Y</header>
    <separator>,</separator>
    <quote>"</quote>
    <partition_by/>
    <coalesce/>
    <extra_options/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>544</xloc>
      <yloc>96</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <order>
    <hop>
      <from>files/customers-1k.txt</from>
      <to>count by state</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>count by state</from>
      <to>output/group-by.csv</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <notepads/>
  <attributes/>
  <transform_error_handling/>
</pipeline>
