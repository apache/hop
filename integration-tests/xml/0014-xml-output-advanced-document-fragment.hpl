<pipeline>
  <info>
    <name>0014-xml-output-advanced-document-fragment</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Integration test: XML Output (Advanced) DocumentFragment node parses an XML fragment field and inserts it as real XML.</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2026/05/08 14:50:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2026/05/08 14:50:00.000</modified_date>
  </info>
  <notepads>
  </notepads>
  <order>
    <hop>
      <from>products grid</from>
      <to>XML Output (Advanced)</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>products grid</name>
    <type>DataGrid</type>
    <description>Three products, each with its own pre-built XML fragment of metadata.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <data>
      <line>
        <item>SKU-100</item>
        <item>Widget</item>
        <item>9.99</item>
        <item>&lt;weight unit="g"&gt;120&lt;/weight&gt;&lt;color&gt;blue&lt;/color&gt;&lt;tag&gt;hardware&lt;/tag&gt;</item>
      </line>
      <line>
        <item>SKU-200</item>
        <item>Gizmo</item>
        <item>19.95</item>
        <item>&lt;weight unit="g"&gt;240&lt;/weight&gt;&lt;color&gt;red&lt;/color&gt;&lt;dimensions w="10" h="5" d="3"/&gt;</item>
      </line>
      <line>
        <item>SKU-300</item>
        <item>Gadget</item>
        <item>49.50</item>
        <item>&lt;weight unit="g"&gt;560&lt;/weight&gt;&lt;color&gt;graphite&lt;/color&gt;&lt;notes priority="low"&gt;Premium edition. Special characters like &amp;amp; or &amp;lt; are preserved as text.&lt;/notes&gt;</item>
      </line>
    </data>
    <fields>
      <field>
        <length>-1</length>
        <precision>-1</precision>
        <currency/>
        <set_empty_string>N</set_empty_string>
        <name>sku</name>
        <format/>
        <group/>
        <decimal/>
        <type>String</type>
      </field>
      <field>
        <length>-1</length>
        <precision>-1</precision>
        <currency/>
        <set_empty_string>N</set_empty_string>
        <name>name</name>
        <format/>
        <group/>
        <decimal/>
        <type>String</type>
      </field>
      <field>
        <length>-1</length>
        <precision>2</precision>
        <currency/>
        <set_empty_string>N</set_empty_string>
        <name>price</name>
        <format>0.00</format>
        <group/>
        <decimal>.</decimal>
        <type>Number</type>
      </field>
      <field>
        <length>-1</length>
        <precision>-1</precision>
        <currency/>
        <set_empty_string>N</set_empty_string>
        <name>extras</name>
        <format/>
        <group/>
        <decimal/>
        <type>String</type>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>96</xloc>
      <yloc>192</yloc>
    </GUI>
  </transform>
  <transform>
    <name>XML Output (Advanced)</name>
    <type>AdvancedXMLOutput</type>
    <description>products/product(loop) with an Element name and a DocumentFragment that injects the &quot;extras&quot; field as XML.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <encoding>UTF-8</encoding>
    <compact_file>N</compact_file>
    <blank_line_after_xml_decl>Y</blank_line_after_xml_decl>
    <create_attr_if_null>N</create_attr_if_null>
    <create_attr_if_unmapped>N</create_attr_if_unmapped>
    <create_empty_element>Y</create_empty_element>
    <trim_values>N</trim_values>
    <generate_xsd>Y</generate_xsd>
    <doctype_root/>
    <doctype_system/>
    <doctype_public/>
    <xsl_stylesheet_href/>
    <xsl_stylesheet_type>text/xsl</xsl_stylesheet_type>
    <file>
      <name>${java.io.tmpdir}/hop-xml-integration-output/0014-document-fragment</name>
      <extension>xml</extension>
      <splitevery>0</splitevery>
      <split>N</split>
      <add_date>N</add_date>
      <add_time>N</add_time>
      <zipped>N</zipped>
      <add_to_result_filenames>Y</add_to_result_filenames>
      <do_not_open_newfile_init>N</do_not_open_newfile_init>
      <do_not_create_empty_file>Y</do_not_create_empty_file>
      <SpecifyFormat>N</SpecifyFormat>
      <date_time_format/>
    </file>
    <tree>
      <name>products</name>
      <kind>Element</kind>
      <children>
        <node>
          <name>product</name>
          <kind>Element</kind>
          <loop>Y</loop>
          <children>
            <node>
              <name>sku</name>
              <kind>Attribute</kind>
              <mapped_field>sku</mapped_field>
            </node>
            <node>
              <name>name</name>
              <kind>Element</kind>
              <mapped_field>name</mapped_field>
            </node>
            <node>
              <name>price</name>
              <kind>Element</kind>
              <mapped_field>price</mapped_field>
              <format>0.00</format>
            </node>
            <node>
              <name>extras</name>
              <kind>DocumentFragment</kind>
              <mapped_field>extras</mapped_field>
            </node>
          </children>
        </node>
      </children>
    </tree>
    <attributes/>
    <GUI>
      <xloc>320</xloc>
      <yloc>192</yloc>
    </GUI>
  </transform>
  <transform_error_handling>
  </transform_error_handling>
  <attributes/>
</pipeline>
