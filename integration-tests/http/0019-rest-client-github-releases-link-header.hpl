<pipeline>
  <info>
    <pipeline_version/>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <pipeline_type>Normal</pipeline_type>
    <pipeline_status>0</pipeline_status>
    <parameters>
      <parameter>
        <name>PRM_MIN_RELEASE_ROWS</name>
        <description>Minimum rows expected; with per_page=5 this proves Link-header pagination fetched more than one page.</description>
        <default_value>6</default_value>
      </parameter>
    </parameters>
    <name>0019-rest-client-github-releases-link-header</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description/>
    <extended_description/>
    <created_user>-</created_user>
    <modified_user>-</modified_user>
    <created_date>2026/05/16 14:00:00.000</created_date>
    <modified_date>2026/05/16 14:00:00.000</modified_date>
  </info>
  <transform>
    <type>Abort</type>
    <name>Abort validation failed</name>
    <row_threshold>0</row_threshold>
    <message>GitHub releases pagination validation failed</message>
    <always_log_rows>Y</always_log_rows>
    <abort_option>ABORT_WITH_ERROR</abort_option>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>1488</xloc>
      <yloc>384</yloc>
    </GUI>
    <description/>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>Constant</type>
    <name>GitHub request headers</name>
    <fields>
      <field>
        <nullif>Hop-0019-rest-client-github-releases-link-header</nullif>
        <name>user_agent</name>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <set_empty_string>N</set_empty_string>
      </field>
      <field>
        <nullif>application/vnd.github+json</nullif>
        <name>accept_media</name>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <set_empty_string>N</set_empty_string>
      </field>
    </fields>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>320</xloc>
      <yloc>272</yloc>
    </GUI>
    <description/>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>GroupBy</type>
    <name>aggregate release counts</name>
    <all_rows>N</all_rows>
    <directory>${java.io.tmpdir}</directory>
    <prefix>grp</prefix>
    <ignore_aggregate>N</ignore_aggregate>
    <group/>
    <fields>
      <field>
        <aggregate>row_count</aggregate>
        <subject>tag_name</subject>
        <type>COUNT_ANY</type>
        <valuefield/>
      </field>
      <field>
        <aggregate>distinct_tag_count</aggregate>
        <subject>tag_name</subject>
        <type>COUNT_DISTINCT</type>
        <valuefield/>
      </field>
    </fields>
    <add_linenr>N</add_linenr>
    <give_back_row>N</give_back_row>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>1120</xloc>
      <yloc>272</yloc>
    </GUI>
    <description/>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>Rest</type>
    <name>fetch apache-hop releases</name>
    <applicationType>JSON</applicationType>
    <connection_name>github-releases</connection_name>
    <url>/repos/apache/hop/releases?per_page=5</url>
    <urlInField>N</urlInField>
    <httpPassword>Encrypted </httpPassword>
    <preemptive>N</preemptive>
    <method>GET</method>
    <dynamicMethod>N</dynamicMethod>
    <trustStorePassword>Encrypted </trustStorePassword>
    <connectionTimeout>60000</connectionTimeout>
    <readTimeout>60000</readTimeout>
    <ignoreSsl>N</ignoreSsl>
    <headers>
      <header>
        <field>user_agent</field>
        <name>User-Agent</name>
      </header>
      <header>
        <field>accept_media</field>
        <name>Accept</name>
      </header>
    </headers>
    <parameters/>
    <matrixParameters/>
    <result>
      <name>release_json</name>
    </result>
    <retryTimes>0</retryTimes>
    <retryDelayMs>200</retryDelayMs>
    <retryStatusCodes/>
    <retryMethods/>
    <paginationEnabled>Y</paginationEnabled>
    <maxPagesLoops>8</maxPagesLoops>
    <resultSplitPath>$[*]</resultSplitPath>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>528</xloc>
      <yloc>272</yloc>
    </GUI>
    <description/>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>RowGenerator</type>
    <name>generate 1 row</name>
    <never_ending>N</never_ending>
    <interval_in_ms>5000</interval_in_ms>
    <row_time_field>now</row_time_field>
    <last_time_field>FiveSecondsAgo</last_time_field>
    <limit>1</limit>
    <fields/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>128</xloc>
      <yloc>272</yloc>
    </GUI>
    <description/>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>FilterRows</type>
    <name>pagination ok?</name>
    <compare>
      <condition>
        <negated>N</negated>
        <operator>-</operator>
        <function>=</function>
        <conditions>
          <condition>
            <negated>N</negated>
            <operator>-</operator>
            <leftvalue>row_count</leftvalue>
            <function>&gt;=</function>
            <rightvalue>min_pages</rightvalue>
            <conditions/>
          </condition>
          <condition>
            <negated>N</negated>
            <operator>AND</operator>
            <leftvalue>row_count</leftvalue>
            <function>=</function>
            <rightvalue>distinct_tag_count</rightvalue>
            <conditions/>
          </condition>
        </conditions>
      </condition>
    </compare>
    <send_true_to>success</send_true_to>
    <send_false_to>Abort validation failed</send_false_to>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>1488</xloc>
      <yloc>272</yloc>
    </GUI>
    <description/>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>JsonInput</type>
    <name>parse release JSON</name>
    <include>N</include>
    <include_field/>
    <rownum>N</rownum>
    <rownum_field/>
    <limit>0</limit>
    <valueField>release_json</valueField>
    <IsInFields>Y</IsInFields>
    <IsAFile>N</IsAFile>
    <addresultfile>N</addresultfile>
    <IsIgnoreEmptyFile>Y</IsIgnoreEmptyFile>
    <doNotFailIfNoFile>N</doNotFailIfNoFile>
    <ignoreMissingPath>Y</ignoreMissingPath>
    <readurl>N</readurl>
    <removeSourceField>Y</removeSourceField>
    <defaultPathLeafToNull>Y</defaultPathLeafToNull>
    <files>
      <file>
        <name/>
        <filemask/>
        <exclude_filemask/>
        <file_required>N</file_required>
        <include_subfolders>N</include_subfolders>
      </file>
    </files>
    <fields>
      <field>
        <name>tag_name</name>
        <length>-1</length>
        <type>String</type>
        <format/>
        <trim_type>none</trim_type>
        <precision>-1</precision>
        <currency/>
        <decimal/>
        <group/>
        <repeat>N</repeat>
        <path>$.tag_name</path>
      </field>
      <field>
        <name>html_url</name>
        <length>-1</length>
        <type>String</type>
        <format/>
        <trim_type>none</trim_type>
        <precision>-1</precision>
        <currency/>
        <decimal/>
        <group/>
        <repeat>N</repeat>
        <path>$.html_url</path>
      </field>
    </fields>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>736</xloc>
      <yloc>272</yloc>
    </GUI>
    <description/>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>FilterRows</type>
    <name>release fields ok?</name>
    <compare>
      <condition>
        <negated>N</negated>
        <operator>-</operator>
        <leftvalue>tag_name</leftvalue>
        <function>IS NOT NULL</function>
        <conditions>
          <condition>
            <negated>N</negated>
            <operator>-</operator>
            <leftvalue>tag_name</leftvalue>
            <function>IS NOT NULL</function>
            <conditions/>
          </condition>
          <condition>
            <negated>N</negated>
            <operator>AND</operator>
            <leftvalue>html_url</leftvalue>
            <function>IS NOT NULL</function>
            <conditions/>
          </condition>
          <condition>
            <negated>N</negated>
            <operator>AND</operator>
            <leftvalue>html_url</leftvalue>
            <function>STARTS WITH</function>
            <value>
              <name>constant</name>
              <type>String</type>
              <text>https://github.com/apache/hop/releases/tag/</text>
              <length>-1</length>
              <precision>-1</precision>
              <isnull>N</isnull>
              <mask/>
            </value>
            <conditions/>
          </condition>
        </conditions>
      </condition>
    </compare>
    <send_true_to>aggregate release counts</send_true_to>
    <send_false_to>Abort validation failed</send_false_to>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>928</xloc>
      <yloc>272</yloc>
    </GUI>
    <description/>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>Dummy</type>
    <name>success</name>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>1696</xloc>
      <yloc>272</yloc>
    </GUI>
    <description/>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>GetVariable</type>
    <name>Get variables</name>
    <fields>
      <field>
        <name>min_pages</name>
        <variable>${PRM_MIN_RELEASE_ROWS}</variable>
        <type>Integer</type>
        <format/>
        <length>-1</length>
        <precision>-1</precision>
        <currency/>
        <decimal/>
        <group/>
        <trim_type>none</trim_type>
      </field>
    </fields>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>1312</xloc>
      <yloc>272</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <order>
    <hop>
      <from>generate 1 row</from>
      <to>GitHub request headers</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>GitHub request headers</from>
      <to>fetch apache-hop releases</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>fetch apache-hop releases</from>
      <to>parse release JSON</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>parse release JSON</from>
      <to>release fields ok?</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>release fields ok?</from>
      <to>aggregate release counts</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>release fields ok?</from>
      <to>Abort validation failed</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>pagination ok?</from>
      <to>success</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>pagination ok?</from>
      <to>Abort validation failed</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>aggregate release counts</from>
      <to>Get variables</to>
