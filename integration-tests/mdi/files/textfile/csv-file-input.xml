<transform>
    <filename>filename.csv</filename>
    <filename_field>filenameField</filename_field>
    <rownum_field>rowNum</rownum_field>
    <include_filename>Y</include_filename>
    <separator>,</separator>
    <enclosure>&#34;</enclosure>
    <header>Y</header>
    <buffer_size>50000</buffer_size>
    <schemaDefinition>fields</schemaDefinition>
    <ignoreFields>Y</ignoreFields>
    <lazy_conversion>Y</lazy_conversion>
    <add_filename_result>Y</add_filename_result>
    <parallel>Y</parallel>
    <newline_possible>Y</newline_possible>
    <encoding>UTF-8</encoding>
    <fields>
        <field>
            <name>id</name>
            <type>Integer</type>
            <format/>
            <currency/>
            <decimal/>
            <group/>
            <length>9</length>
            <precision>0</precision>
            <trim_type>both</trim_type>
        </field>
        <field>
            <name>name</name>
            <type>String</type>
            <format/>
            <currency/>
            <decimal/>
            <group/>
            <length>100</length>
            <precision>-1</precision>
            <trim_type>right</trim_type>
        </field>
    </fields>
</transform>
