<transform>
    <include>Y</include>
    <include_field>filename</include_field>
    <rownum>Y</rownum>
    <addresultfile>Y</addresultfile>
    <IsIgnoreEmptyFile>Y</IsIgnoreEmptyFile>
    <IsIgnoreMissingPath>Y</IsIgnoreMissingPath>
    <rownum_field>rowNum</rownum_field>
    <encoding>UTF-8</encoding>
    <file>
        <name>sample-file1.txt</name>
        <filemask>mask1</filemask>
        <exclude_filemask>excludeMask1</exclude_filemask>
        <file_required>Y</file_required>
        <include_subfolders>Y</include_subfolders>
        <name>sample-file2.txt</name>
        <filemask>mask2</filemask>
        <exclude_filemask>excludeMask2</exclude_filemask>
        <file_required>Y</file_required>
        <include_subfolders>Y</include_subfolders>
    </file>
    <fields>
        <field>
            <name>File content</name>
            <element_type>content</element_type>
            <type>String</type>
            <format/>
            <currency/>
            <decimal/>
            <group/>
            <length>65535</length>
            <precision>-1</precision>
            <trim_type>none</trim_type>
            <repeat>N</repeat>
        </field>
        <field>
            <name>File size</name>
            <element_type>size</element_type>
            <type>Integer</type>
            <format/>
            <currency/>
            <decimal/>
            <group/>
            <length>6</length>
            <precision>-1</precision>
            <trim_type>none</trim_type>
            <repeat>N</repeat>
        </field>
    </fields>
    <limit>999</limit>
    <IsInFields>Y</IsInFields>
    <DynamicFilenameField>dynamicField</DynamicFilenameField>
    <shortFileFieldName>shortFile</shortFileFieldName>
    <pathFieldName>path</pathFieldName>
    <hiddenFieldName>hidden</hiddenFieldName>
    <lastModificationTimeFieldName>lastUpd</lastModificationTimeFieldName>
    <uriNameFieldName>uri</uriNameFieldName>
    <rootUriNameFieldName>rootUri</rootUriNameFieldName>
    <extensionFieldName>extension</extensionFieldName>
</transform>
