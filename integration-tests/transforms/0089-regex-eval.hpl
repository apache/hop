<pipeline>
  <info>
    <name>0089-regex-eval</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description/>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2026/03/25 11:18:55.162</created_date>
    <modified_user>-</modified_user>
    <modified_date>2026/03/25 11:18:55.162</modified_date>
  </info>
  <notepads>
  </notepads>
  <order>
    <hop>
      <from>strings</from>
      <to>match hop</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>match hop</from>
      <to>Validate</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>capture groups</from>
      <to>Validate capture groups</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>strings</from>
      <to>capture groups</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>strings</name>
    <type>DataGrid</type>
    <description/>
    <distribute>N</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <data>
      <line>
        <item>Apache Hop From The Apache Software Foundation.</item>
      </line>
      <line>
        <item>Spark from the Apache Software Foundation is great.</item>
      </line>
    </data>
    <fields>
      <field>
        <length>-1</length>
        <precision>-1</precision>
        <currency/>
        <set_empty_string>N</set_empty_string>
        <name>string</name>
        <format/>
        <group/>
        <decimal/>
        <type>String</type>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>96</xloc>
      <yloc>64</yloc>
    </GUI>
  </transform>
  <transform>
    <name>match hop</name>
    <type>RegexEval</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <allowcapturegroups>N</allowcapturegroups>
    <canoneq>N</canoneq>
    <caseinsensitive>Y</caseinsensitive>
    <comment>N</comment>
    <dotall>N</dotall>
    <fields>
</fields>
    <matcher>string</matcher>
    <multiline>N</multiline>
    <replacefields>Y</replacefields>
    <resultfieldname>matches</resultfieldname>
    <script>.*hop.*</script>
    <unicode>N</unicode>
    <unix>N</unix>
    <usevar>N</usevar>
    <attributes/>
    <GUI>
      <xloc>208</xloc>
      <yloc>64</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Validate</name>
    <type>Dummy</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
    <GUI>
      <xloc>336</xloc>
      <yloc>64</yloc>
    </GUI>
  </transform>
  <transform>
    <name>capture groups</name>
    <type>RegexEval</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <allowcapturegroups>Y</allowcapturegroups>
    <canoneq>N</canoneq>
    <caseinsensitive>Y</caseinsensitive>
    <comment>N</comment>
    <dotall>N</dotall>
    <fields>
      <field>
        <currency/>
        <decimal/>
        <format/>
        <group/>
        <ifnull/>
        <length>-1</length>
        <name>prefix</name>
        <nullif/>
        <precision>-1</precision>
        <trimtype>none</trimtype>
        <type>String</type>
      </field>
      <field>
        <currency/>
        <decimal/>
        <format/>
        <group/>
        <ifnull/>
        <length>-1</length>
        <name>suffix</name>
        <nullif/>
        <precision>-1</precision>
        <trimtype>none</trimtype>
        <type>String</type>
      </field>
    </fields>
    <matcher>string</matcher>
    <multiline>N</multiline>
    <replacefields>N</replacefields>
    <resultfieldname>matches</resultfieldname>
    <script>(.*)Apache Software Foundation(.*)</script>
    <unicode>N</unicode>
    <unix>N</unix>
    <usevar>N</usevar>
    <attributes/>
    <GUI>
      <xloc>208</xloc>
      <yloc>144</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Validate capture groups</name>
    <type>Dummy</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
    <GUI>
      <xloc>336</xloc>
      <yloc>144</yloc>
    </GUI>
  </transform>
  <transform_error_handling>
  </transform_error_handling>
  <attributes/>
</pipeline>
