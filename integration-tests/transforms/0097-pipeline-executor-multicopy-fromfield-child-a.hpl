<pipeline>
  <info>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <pipeline_type>Normal</pipeline_type>
    <pipeline_status>0</pipeline_status>
    <parameters>
      <parameter>
        <name>P_EXPECTED_CHILD</name>
        <description>Marker from parent row; must be A in this pipeline.</description>
      </parameter>
    </parameters>
    <name>0097-pipeline-executor-multicopy-fromfield-child-a</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Child A: succeeds only when P_EXPECTED_CHILD is A.</description>
    <created_user>-</created_user>
    <modified_user>-</modified_user>
    <created_date>2026/04/16 12:00:00.000</created_date>
    <modified_date>2026/04/16 12:00:00.000</modified_date>
  </info>
  <transform>
    <type>Abort</type>
    <name>Abort wrong pipeline or parameter</name>
    <row_threshold>0</row_threshold>
    <always_log_rows>Y</always_log_rows>
    <abort_option>ABORT_WITH_ERROR</abort_option>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>752</xloc>
      <yloc>272</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>RowGenerator</type>
    <name>Generate rows</name>
    <never_ending>N</never_ending>
    <interval_in_ms>5000</interval_in_ms>
    <row_time_field>now</row_time_field>
    <last_time_field>FiveSecondsAgo</last_time_field>
    <limit>1</limit>
    <fields/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>128</xloc>
      <yloc>160</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>Constant</type>
    <name>Label this pipeline A</name>
    <fields>
      <field>
        <nullif>A</nullif>
        <name>local_label</name>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <set_empty_string>N</set_empty_string>
      </field>
    </fields>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>544</xloc>
      <yloc>160</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>Dummy</type>
    <name>OK</name>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>960</xloc>
      <yloc>160</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>FilterRows</type>
    <name>Parameter matches this child</name>
    <compare>
      <condition>
        <negated>N</negated>
        <operator>-</operator>
        <leftvalue>expected_from_param</leftvalue>
        <function>=</function>
        <rightvalue>local_label</rightvalue>
        <conditions/>
      </condition>
    </compare>
    <send_true_to>OK</send_true_to>
    <send_false_to>Abort wrong pipeline or parameter</send_false_to>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>752</xloc>
      <yloc>160</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>GetVariable</type>
    <name>Read expected from parameter</name>
    <fields>
      <field>
        <name>expected_from_param</name>
        <variable>${P_EXPECTED_CHILD}</variable>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
      </field>
    </fields>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>336</xloc>
      <yloc>160</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <order>
    <hop>
      <from>Generate rows</from>
      <to>Read expected from parameter</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Read expected from parameter</from>
      <to>Label this pipeline A</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Label this pipeline A</from>
      <to>Parameter matches this child</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Parameter matches this child</from>
      <to>OK</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Parameter matches this child</from>
      <to>Abort wrong pipeline or parameter</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <notepads/>
  <attributes/>
  <transform_error_handling/>
</pipeline>
