<pipeline>
  <info>
    <name>0105-fake-data-legacy-types</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Guards backward compatibility: fields stored with the pre-DataFaker capitalized type names (Name, PhoneNumber, Number) must still resolve to a working generator and produce non-null, in-range values. Any failure routes a row to Abort.</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2020/12/16 12:25:44.129</created_date>
    <modified_user>-</modified_user>
    <modified_date>2020/12/16 12:25:44.129</modified_date>
  </info>
  <notepads>
  </notepads>
  <order>
    <hop>
      <from>50 rows</from>
      <to>generate legacy</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>generate legacy</from>
      <to>invalid?</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>invalid?</from>
      <to>Abort</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>invalid?</from>
      <to>ok</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>50 rows</name>
    <type>RowGenerator</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
    </fields>
    <limit>50</limit>
    <never_ending>N</never_ending>
    <interval_in_ms>5000</interval_in_ms>
    <row_time_field>now</row_time_field>
    <last_time_field>FiveSecondsAgo</last_time_field>
    <attributes/>
    <GUI>
      <xloc>128</xloc>
      <yloc>96</yloc>
    </GUI>
  </transform>
  <transform>
    <name>generate legacy</name>
    <type>Fake</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <locale>en</locale>
    <fields>
      <field>
        <name>full_name</name>
        <type>Name</type>
        <topic>fullName</topic>
        <arguments/>
      </field>
      <field>
        <name>phone</name>
        <type>PhoneNumber</type>
        <topic>phoneNumber</topic>
        <arguments/>
      </field>
      <field>
        <name>digit</name>
        <type>Number</type>
        <topic>randomDigit</topic>
        <arguments/>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>272</xloc>
      <yloc>96</yloc>
    </GUI>
  </transform>
  <transform>
    <name>invalid?</name>
    <type>FilterRows</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <send_true_to>Abort</send_true_to>
    <send_false_to>ok</send_false_to>
    <compare>
      <condition>
        <conditions>
          <condition>
            <conditions>
</conditions>
            <function>IS NULL</function>
            <leftvalue>full_name</leftvalue>
            <negated>N</negated>
            <operator>-</operator>
            <rightvalue/>
          </condition>
          <condition>
            <conditions>
</conditions>
            <function>IS NULL</function>
            <leftvalue>phone</leftvalue>
            <negated>N</negated>
            <operator>OR</operator>
            <rightvalue/>
          </condition>
          <condition>
            <conditions>
</conditions>
            <function>&lt;</function>
            <leftvalue>digit</leftvalue>
            <negated>N</negated>
            <operator>OR</operator>
            <value>
              <isnull>N</isnull>
              <length>-1</length>
              <name>constant</name>
              <precision>0</precision>
              <text>0</text>
              <type>Integer</type>
            </value>
          </condition>
          <condition>
            <conditions>
</conditions>
            <function>&gt;</function>
            <leftvalue>digit</leftvalue>
            <negated>N</negated>
            <operator>OR</operator>
            <value>
              <isnull>N</isnull>
              <length>-1</length>
              <name>constant</name>
              <precision>0</precision>
              <text>9</text>
              <type>Integer</type>
            </value>
          </condition>
        </conditions>
        <negated>N</negated>
        <operator>-</operator>
        <value>
          <isnull>N</isnull>
          <length>0</length>
          <precision>0</precision>
        </value>
      </condition>
    </compare>
    <attributes/>
    <GUI>
      <xloc>432</xloc>
      <yloc>96</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Abort</name>
    <type>Abort</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <row_threshold>0</row_threshold>
    <message>A legacy-typed fake field failed to resolve or produced a null/out-of-range value</message>
    <always_log_rows>Y</always_log_rows>
    <abort_option>ABORT_WITH_ERROR</abort_option>
    <attributes/>
    <GUI>
      <xloc>592</xloc>
      <yloc>96</yloc>
    </GUI>
  </transform>
  <transform>
    <name>ok</name>
    <type>Dummy</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
    <GUI>
      <xloc>592</xloc>
      <yloc>208</yloc>
    </GUI>
  </transform>
  <transform_error_handling>
  </transform_error_handling>
  <attributes/>
</pipeline>
