<pipeline>
  <info>
    <pipeline_version/>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <pipeline_type>Normal</pipeline_type>
    <pipeline_status>0</pipeline_status>
    <parameters>
      <parameter>
        <name>PRM_MIN_PULL_ROWS</name>
        <description>Minimum pull-request rows; with per_page=100 this proves Link-header pagination across multiple pages.</description>
        <default_value>250</default_value>
      </parameter>
    </parameters>
    <name>0102-rest-client-github-pulls-link-header</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description/>
    <extended_description/>
    <created_user>-</created_user>
    <modified_user>-</modified_user>
    <created_date>2026/06/06 12:00:00.000</created_date>
    <modified_date>2026/06/06 12:00:00.000</modified_date>
  </info>
  <transform>
    <type>Abort</type>
    <name>Abort validation failed</name>
    <row_threshold>0</row_threshold>
    <message>GitHub hop-website pull-request pagination validation failed</message>
    <always_log_rows>Y</always_log_rows>
    <abort_option>ABORT_WITH_ERROR</abort_option>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>1488</xloc>
      <yloc>384</yloc>
    </GUI>
    <description/>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>Constant</type>
    <name>GitHub request headers</name>
    <fields>
      <field>
        <nullif>Hop-0102-rest-client-github-pulls-link-header</nullif>
        <name>user_agent</name>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <set_empty_string>N</set_empty_string>
      </field>
      <field>
        <nullif>application/vnd.github+json</nullif>
        <name>accept_media</name>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <set_empty_string>N</set_empty_string>
      </field>
    </fields>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>320</xloc>
      <yloc>272</yloc>
    </GUI>
    <description/>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>GroupBy</type>
    <name>aggregate pull counts</name>
    <all_rows>N</all_rows>
    <directory>${java.io.tmpdir}</directory>
    <prefix>grp</prefix>
    <ignore_aggregate>N</ignore_aggregate>
    <group/>
    <fields>
      <field>
        <aggregate>row_count</aggregate>
        <subject>pr_number</subject>
        <type>COUNT_ANY</type>
        <valuefield/>
      </field>
      <field>
        <aggregate>distinct_pr_count</aggregate>
        <subject>pr_number</subject>
        <type>COUNT_DISTINCT</type>
        <valuefield/>
      </field>
    </fields>
    <add_linenr>N</add_linenr>
    <give_back_row>N</give_back_row>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>1120</xloc>
      <yloc>272</yloc>
    </GUI>
    <description/>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>Rest</type>
    <name>fetch hop-website pull requests</name>
    <applicationType>JSON</applicationType>
    <connection_name>github-hop-website</connection_name>
    <url>/repos/apache/hop-website/pulls?state=all&amp;per_page=100</url>
    <urlInField>N</urlInField>
    <httpPassword>Encrypted </httpPassword>
    <preemptive>N</preemptive>
    <method>GET</method>
    <dynamicMethod>N</dynamicMethod>
    <trustStorePassword>Encrypted </trustStorePassword>
    <connectionTimeout>120000</connectionTimeout>
    <readTimeout>120000</readTimeout>
    <ignoreSsl>N</ignoreSsl>
    <headers>
      <header>
        <field>user_agent</field>
        <name>User-Agent</name>
      </header>
      <header>
        <field>accept_media</field>
        <name>Accept</name>
      </header>
    </headers>
    <parameters/>
    <matrixParameters/>
    <result>
      <name>pull_json</name>
    </result>
    <retryTimes>0</retryTimes>
    <retryDelayMs>200</retryDelayMs>
    <retryStatusCodes/>
    <retryMethods/>
    <paginationEnabled>Y</paginationEnabled>
    <maxPagesLoops>5</maxPagesLoops>
    <resultSplitPath>$[*]</resultSplitPath>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>528</xloc>
      <yloc>272</yloc>
    </GUI>
    <description/>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>RowGenerator</type>
    <name>generate 1 row</name>
    <never_ending>N</never_ending>
    <interval_in_ms>5000</interval_in_ms>
    <row_time_field>now</row_time_field>
    <last_time_field>FiveSecondsAgo</last_time_field>
    <limit>1</limit>
    <fields/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>128</xloc>
      <yloc>272</yloc>
    </GUI>
    <description/>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>FilterRows</type>
    <name>pagination ok?</name>
    <compare>
      <condition>
        <negated>N</negated>
        <operator>-</operator>
        <function>=</function>
        <conditions>
          <condition>
            <negated>N</negated>
            <operator>-</operator>
            <leftvalue>row_count</leftvalue>
            <function>&gt;=</function>
            <rightvalue>min_pull_rows</rightvalue>
            <conditions/>
          </condition>
          <condition>
            <negated>N</negated>
            <operator>AND</operator>
            <leftvalue>row_count</leftvalue>
            <function>=</function>
            <rightvalue>distinct_pr_count</rightvalue>
            <conditions/>
          </condition>
        </conditions>
      </condition>
    </compare>
    <send_true_to>success</send_true_to>
    <send_false_to>Abort validation failed</send_false_to>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>1488</xloc>
      <yloc>272</yloc>
    </GUI>
    <description/>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>JsonInput</type>
    <name>parse pull JSON</name>
    <include>N</include>
    <include_field/>
    <rownum>N</rownum>
    <rownum_field/>
    <limit>0</limit>
    <valueField>pull_json</valueField>
    <IsInFields>Y</IsInFields>
    <IsAFile>N</IsAFile>
    <addresultfile>N</addresultfile>
    <IsIgnoreEmptyFile>Y</IsIgnoreEmptyFile>
    <doNotFailIfNoFile>N</doNotFailIfNoFile>
    <ignoreMissingPath>Y</ignoreMissingPath>
    <readurl>N</readurl>
    <removeSourceField>Y</removeSourceField>
    <defaultPathLeafToNull>Y</defaultPathLeafToNull>
    <files>
      <file>
        <name/>
        <filemask/>
        <exclude_filemask/>
        <file_required>N</file_required>
        <include_subfolders>N</include_subfolders>
      </file>
    </files>
    <fields>
      <field>
        <name>pr_number</name>
        <length>-1</length>
        <type>Integer</type>
        <format/>
        <trim_type>none</trim_type>
        <precision>-1</precision>
        <currency/>
        <decimal/>
        <group/>
        <repeat>N</repeat>
        <path>$.number</path>
      </field>
      <field>
        <name>html_url</name>
        <length>-1</length>
        <type>String</type>
        <format/>
        <trim_type>none</trim_type>
        <precision>-1</precision>
        <currency/>
        <decimal/>
        <group/>
        <repeat>N</repeat>
        <path>$.html_url</path>
      </field>
    </fields>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>736</xloc>
      <yloc>272</yloc>
    </GUI>
    <description/>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>FilterRows</type>
    <name>pull fields ok?</name>
    <compare>
      <condition>
        <negated>N</negated>
        <operator>-</operator>
        <leftvalue>pr_number</leftvalue>
        <function>IS NOT NULL</function>
        <conditions>
          <condition>
            <negated>N</negated>
            <operator>-</operator>
            <leftvalue>pr_number</leftvalue>
            <function>IS NOT NULL</function>
            <conditions/>
          </condition>
          <condition>
            <negated>N</negated>
            <operator>AND</operator>
            <leftvalue>html_url</leftvalue>
            <function>IS NOT NULL</function>
            <conditions/>
          </condition>
          <condition>
            <negated>N</negated>
            <operator>AND</operator>
            <leftvalue>html_url</leftvalue>
            <function>STARTS WITH</function>
            <value>
              <name>constant</name>
              <type>String</type>
              <text>https://github.com/apache/hop-website/pull/</text>
              <length>-1</length>
              <precision>-1</precision>
              <isnull>N</isnull>
              <mask/>
            </value>
            <conditions/>
          </condition>
        </conditions>
      </condition>
    </compare>
    <send_true_to>aggregate pull counts</send_true_to>
    <send_false_to>Abort validation failed</send_false_to>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>928</xloc>
      <yloc>272</yloc>
    </GUI>
    <description/>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>Dummy</type>
    <name>success</name>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>1696</xloc>
      <yloc>272</yloc>
    </GUI>
    <description/>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>GetVariable</type>
    <name>Get variables</name>
    <fields>
      <field>
        <name>min_pull_rows</name>
        <variable>${PRM_MIN_PULL_ROWS}</variable>
        <type>Integer</type>
        <format/>
        <length>-1</length>
        <precision>-1</precision>
        <currency/>
        <decimal/>
        <group/>
        <trim_type>none</trim_type>
      </field>
    </fields>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>1312</xloc>
      <yloc>272</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <order>
    <hop>
      <from>generate 1 row</from>
      <to>GitHub request headers</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>GitHub request headers</from>
      <to>fetch hop-website pull requests</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>fetch hop-website pull requests</from>
      <to>parse pull JSON</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>parse pull JSON</from>
      <to>pull fields ok?</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>pull fields ok?</from>
      <to>aggregate pull counts</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>pull fields ok?</from>
      <to>Abort validation failed</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>pagination ok?</from>
      <to>success</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>pagination ok?</from>
      <to>Abort validation failed</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>aggregate pull counts</from>
      <to>Get variables</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Get variables</from>
      <to>pagination ok?</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <notepads>
    <notepad>
      <note>Integration test: live GET /repos/apache/hop-website/pulls?state=all&amp;per_page=100 with LINK_HEADER pagination. No golden data.

Passes when row_count &gt;= ${PRM_MIN_PULL_ROWS} (default 250, ~3 pages of 100) and row_count equals distinct pr_number. Requires User-Agent. state=all is required (open-only would be far fewer rows).
</note>
