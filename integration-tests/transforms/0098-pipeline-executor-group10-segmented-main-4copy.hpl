      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Assert child pipelines succeeded</from>
      <to>Abort on child failure</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <notepads>
    <notepad>
      <note>group_size=10: two full batches (rows 1-10 child A, 11-20 child B). filenameInField uses child_path; static filename in meta is child-b. Child pipelines abort if any result row has the wrong expected_child. copies=4.</note>
