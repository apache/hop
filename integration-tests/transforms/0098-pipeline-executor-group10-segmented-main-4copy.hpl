    <parameters/>
    <name>0098-pipeline-executor-group10-segmented-main-4copy</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Regression: Pipeline executor group_size=10 with filename from field. Twenty rows in two homogeneous batches (rows 1-10 child A, 11-20 child B). Each child run must receive only rows whose expected_child matches that pipeline. Four executor copies stress shared-meta races.</description>
    <created_user>-</created_user>
    <modified_user>-</modified_user>
    <created_date>2026/04/16 12:00:00.000</created_date>
    <modified_date>2026/04/16 12:00:00.000</modified_date>
  </info>
