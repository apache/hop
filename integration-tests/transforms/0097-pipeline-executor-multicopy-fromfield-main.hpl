      <yloc>160</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>Abort</type>
    <name>Abort on child failure</name>
    <row_threshold>0</row_threshold>
    <always_log_rows>Y</always_log_rows>
    <abort_option>ABORT_WITH_ERROR</abort_option>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>800</xloc>
      <yloc>320</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>FilterRows</type>
    <name>Assert child pipelines succeeded</name>
    <compare>
      <condition>
        <negated>Y</negated>
        <operator>-</operator>
        <leftvalue>ExecutionNrErrors</leftvalue>
        <function>&gt;</function>
        <value>
          <name>constant</name>
          <type>Integer</type>
          <text>0</text>
          <length>-1</length>
          <precision>0</precision>
          <isnull>N</isnull>
          <mask>####0;-####0</mask>
        </value>
        <conditions/>
      </condition>
    </compare>
    <send_true_to>OK</send_true_to>
    <send_false_to>Abort on child failure</send_false_to>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>800</xloc>
      <yloc>160</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>Dummy</type>
    <name>OK</name>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>1008</xloc>
      <yloc>160</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <order>
    <hop>
      <from>Data grid</from>
      <to>Sort rows</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Sort rows</from>
      <to>Pipeline executor multicopy</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Pipeline executor multicopy</from>
      <to>Assert child pipelines succeeded</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Assert child pipelines succeeded</from>
      <to>OK</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Assert child pipelines succeeded</from>
      <to>Abort on child failure</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <notepads>
    <notepad>
      <note>40 rows alternate child A / child B. Pipeline executor uses 10 copies, filename from field child_path, and maps expected_child to P_EXPECTED_CHILD. 
Each child pipeline aborts unless P_EXPECTED_CHILD matches that child (A vs B). 
This fails when copies share the wrong pipeline template or mismatched parameters.</note>
