<workflow>
  <name>main-0000-james-rest</name>
  <name_sync_with_filename>Y</name_sync_with_filename>
  <description/>
  <extended_description/>
  <workflow_version/>
  <created_user>-</created_user>
  <created_date>2025/02/14 19:44:15.999</created_date>
  <modified_user>-</modified_user>
  <modified_date>2025/02/14 19:44:15.999</modified_date>
  <parameters>
    </parameters>
  <actions>
    <action>
      <name>Start</name>
      <description/>
      <type>SPECIAL</type>
      <attributes/>
      <DayOfMonth>1</DayOfMonth>
      <hour>12</hour>
      <intervalMinutes>60</intervalMinutes>
      <intervalSeconds>0</intervalSeconds>
      <minutes>0</minutes>
      <repeat>N</repeat>
      <schedulerType>0</schedulerType>
      <weekDay>1</weekDay>
      <parallel>N</parallel>
      <xloc>64</xloc>
      <yloc>64</yloc>
      <attributes_hac/>
    </action>
    <action>
      <name>add domains, users</name>
      <description/>
      <type>SHELL</type>
      <attributes/>
      <filename/>
      <work_directory/>
      <arg_from_previous>N</arg_from_previous>
      <exec_per_row>N</exec_per_row>
      <set_logfile>N</set_logfile>
      <logfile/>
      <set_append_logfile>N</set_append_logfile>
      <logext/>
      <add_date>N</add_date>
      <add_time>N</add_time>
      <insertScript>Y</insertScript>
      <script>#!/bin/bash 

curl -XPUT http://${MAIL_SMTP_SERVER}:8000/domains/example.com
curl -XPUT http://${MAIL_SMTP_SERVER}:8000/domains/acme.be

curl -XPUT http://${MAIL_SMTP_SERVER}:8000/users/user01@example.com   -d '{"password":"password"}'    -H "Content-Type: application/json"
curl -XPUT http://${MAIL_SMTP_SERVER}:8000/users/roadrunner@acme.be   -d '{"password":"password"}'    -H "Content-Type: application/json"

</script>
      <loglevel>Basic</loglevel>
      <parallel>N</parallel>
      <xloc>384</xloc>
      <yloc>64</yloc>
      <attributes_hac/>
    </action>
    <action>
      <name>Mail</name>
      <description/>
      <type>MAIL</type>
      <attributes/>
      <auth_password>password</auth_password>
      <auth_user>${MAIL_SENDER_ADDRESS}</auth_user>
      <check_server_identity>N</check_server_identity>
      <comment>test body</comment>
      <destination>user01@example.com</destination>
      <embeddedimages>
</embeddedimages>
      <encoding>UTF-8</encoding>
      <importance>normal</importance>
      <include_date>N</include_date>
      <include_files>N</include_files>
      <only_comment>N</only_comment>
      <port>${MAIL_SMTP_PORT}</port>
      <priority>normal</priority>
      <replyto>user01@example.com</replyto>
      <replytoname>user01@example.com</replytoname>
      <secureconnectiontype>TLS</secureconnectiontype>
      <sensitivity>normal</sensitivity>
      <server>localhost</server>
      <subject>test subject</subject>
      <use_HTML>N</use_HTML>
      <use_Priority>N</use_Priority>
      <use_auth>Y</use_auth>
      <use_secure_auth>Y</use_secure_auth>
      <usexoauth2>N</usexoauth2>
      <zip_files>N</zip_files>
      <parallel>N</parallel>
      <xloc>544</xloc>
      <yloc>64</yloc>
      <attributes_hac/>
    </action>
    <action>
      <name>Wait for</name>
      <description/>
      <type>DELAY</type>
      <attributes/>
      <maximumTimeout>30</maximumTimeout>
      <scaletime>0</scaletime>
      <parallel>N</parallel>
      <xloc>224</xloc>
      <yloc>64</yloc>
      <attributes_hac/>
    </action>
    <action>
      <name>Get mails (POP3/IMAP)</name>
      <description/>
      <type>GET_POP</type>
      <attributes/>
      <servername>localhost</servername>
      <username>user01@example.com</username>
      <password>Encrypted 2be98afc86aa7f2e4bb18bd63c99dbdde</password>
      <usessl>Y</usessl>
      <sslport>993</sslport>
      <usexoauth2>N</usexoauth2>
      <outputdirectory>/Users/bart/Downloads</outputdirectory>
      <filenamepattern>name_{SYS|hhmmss_MMddyyyy|}_#IdFile#.mail</filenamepattern>
      <retrievemails>0</retrievemails>
      <firstmails/>
      <delete>N</delete>
      <savemessage>Y</savemessage>
      <saveattachment>Y</saveattachment>
      <usedifferentfolderforattachment>N</usedifferentfolderforattachment>
      <protocol>IMAP</protocol>
      <attachmentfolder/>
      <attachmentwildcard/>
      <valueimaplist>imaplistall</valueimaplist>
      <imapfirstmails>0</imapfirstmails>
      <imapfolder>INBOX</imapfolder>
      <sendersearch/>
      <nottermsendersearch>N</nottermsendersearch>
      <receipientsearch/>
      <nottermreceipientsearch>N</nottermreceipientsearch>
      <subjectsearch/>
      <nottermsubjectsearch>N</nottermsubjectsearch>
      <bodysearch/>
      <nottermbodysearch>N</nottermbodysearch>
      <conditionreceiveddate>ignore</conditionreceiveddate>
      <nottermreceiveddatesearch>N</nottermreceiveddatesearch>
      <receiveddate1/>
      <receiveddate2/>
      <actiontype>get</actiontype>
      <movetoimapfolder/>
      <createmovetofolder>N</createmovetofolder>
      <createlocalfolder>N</createlocalfolder>
      <aftergetimap>nothing</aftergetimap>
      <includesubfolders>N</includesubfolders>
      <useproxy>N</useproxy>
      <proxyusername/>
      <parallel>N</parallel>
      <xloc>768</xloc>
      <yloc>64</yloc>
      <attributes_hac/>
    </action>
  </actions>
  <hops>
    <hop>
      <from>add domains, users</from>
      <to>Mail</to>
      <enabled>Y</enabled>
      <evaluation>Y</evaluation>
      <unconditional>N</unconditional>
    </hop>
    <hop>
      <from>Start</from>
      <to>Wait for</to>
      <enabled>Y</enabled>
      <evaluation>Y</evaluation>
      <unconditional>Y</unconditional>
    </hop>
    <hop>
      <from>Wait for</from>
      <to>add domains, users</to>
      <enabled>Y</enabled>
      <evaluation>Y</evaluation>
      <unconditional>N</unconditional>
    </hop>
    <hop>
      <from>Mail</from>
      <to>Get mails (POP3/IMAP)</to>
      <enabled>Y</enabled>
      <evaluation>Y</evaluation>
      <unconditional>N</unconditional>
    </hop>
  </hops>
  <notepads>
  </notepads>
  <attributes/>
</workflow>
